generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////
// USER / AUTH
//////////////////////
model User{
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  tel       String
  role      String   // e.g., "admin", "user"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  requests Request[]

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
  TENANT
}

//////////////////////
// MEMBER (ของเดิม)
//////////////////////
model Member {
  id        Int      @id @default(autoincrement())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String   @unique
  phone     String?
  address   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("members")
}

//////////////////////
// ROOM
//////////////////////

enum RoomStatus {
  AVAILABLE
  RESERVED
  FULL
}

model Room {
  id          Int        @id @default(autoincrement())
  roomNo      String     @unique
  roomType    String // คู่ชาย, คู่หญิง, รวมชาย, รวมหญิง
  price       Float
  status      RoomStatus @default(AVAILABLE)
  image       String?
  description String?
  floor       Int

  // relation
  requests Request[]
  dormId   Int?
  dorm     Dorm?     @relation(fields: [dormId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Request {
  id          Int           @id @default(autoincrement())
  title       String
  description String?       @db.Text
  status      RequestStatus @default(PENDING)

  userId Int?
  roomId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
  room Room? @relation(fields: [roomId], references: [id])

  @@map("requests")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

//////////////////////
// DORM
//////////////////////
model Dorm {
  id          Int     @id @default(autoincrement())
  name        String
  description String? @db.Text
  address     String? @db.Text
  phone       String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rooms Room[]

  @@map("dorms")
}

//////////////////////
// STUDENT
//////////////////////
model Student {
  id          Int     @id @default(autoincrement())
  studentCode String  @unique @map("student_code")
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  email       String? @unique
  phone       String?
  faculty     String?
  major       String?
  year        Int?
  address     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("students")
}
